{
  "name": "@caslon/breeze",
  "version": "0.0.0",
  "author": {
    "name": "escapace",
    "email": "opensource@escapace.com"
  },
  "bugs": "https://github.com/escapace/caslon/issues",
  "devDependencies": {
    "@caslon/utopia": "workspace:*",
    "@ls-lint/ls-lint": "2.3.1",
    "@types/node": "24.0.14",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.31.0",
    "eslint-config-escapace": "5.8.0",
    "esroll": "0.4.5",
    "prettier": "3.6.2",
    "prettier-config-escapace": "1.2.1",
    "split-string": "6.1.0",
    "syncpack": "13.0.4",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "3.2.4",
    "zx": "8.7.0"
  },
  "engines": {
    "pnpm": ">=10.10.0"
  },
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/neutral/index.js"
    }
  },
  "files": [
    "lib/neutral",
    "lib/types"
  ],
  "homepage": "https://github.com/escapace/caslon/tree/trunk/packages/breeze#readme",
  "license": "MIT",
  "module": "lib/neutral/index.js",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": "escapace/caslon",
  "scripts": {
    "build": "pnpm run codegen && tsx scripts/build.ts",
    "codegen": "tsx scripts/codegen.ts",
    "format": "syncpack format --source package.json && eslint --no-warn-ignored --fix && prettier -uw .",
    "lint": "ls-lint --config .ls-lint.yaml && eslint",
    "ls-lint": "ls-lint --config .ls-lint.yaml",
    "test": "vitest --no-watch --coverage",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "lib/types/index.d.ts"
}
