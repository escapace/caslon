+const CEPHEUS_REGEX = /^(([a-z]+)|(\d+))(-(\d{1,3})-(\d{1,3}))?([-/](\d{1,2}|100))?$/i
+
+export const resolveCepheusColor = (value: Exclude<Extract<Candidate, { kind: 'functional' }>['value'], null>) => {
+  let result: string | null = null
+
+  if (value.kind === 'arbitrary') {
+    if (CEPHEUS_REGEX.test(value.value)) {
+      result = value.value
+    }
+  } else if (typeof value.fraction === 'string' && CEPHEUS_REGEX.test(value.fraction)) {
+    result = value.fraction.replace('/', '-')
+  } else if (CEPHEUS_REGEX.test(value.value)) {
+    result = value.value
+  }
+
+  if (result === null) {
+    return result
+  }
+
+  return `var(---color-${result})`
+}
