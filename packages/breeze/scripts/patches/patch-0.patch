diff --git i/packages/tailwindcss/src/caslon.ts w/packages/tailwindcss/src/caslon.ts
new file mode 100644
index 00000000..64126dae
--- /dev/null
+++ w/packages/tailwindcss/src/caslon.ts
@@ -0,0 +1,11 @@
+import type { Candidate } from "./candidate"
+
+const CEPHEUS_REGEX = /^(([a-z]+)|(\d+))(-(\d{1,3})-(\d{1,3}))?(-(\d{1,2}|100))?$/i
+
+export const resolveCepheusColor = (value: Exclude<Extract<Candidate, { kind: 'functional' }>['value'], null>) => {
+  if (value.kind === 'named' && CEPHEUS_REGEX.test(value.value)) {
+    return `var(---color-${value.value})`
+  }
+
+  return null
+}
