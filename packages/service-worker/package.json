{
  "name": "@caslon/service-worker",
  "version": "0.0.0",
  "author": {
    "name": "escapace",
    "email": "opensource@escapace.com"
  },
  "bugs": "https://github.com/escapace/caslon/issues",
  "devDependencies": {
    "@ls-lint/ls-lint": "2.3.1",
    "@types/node": "22.15.30",
    "@vitest/coverage-v8": "3.2.2",
    "eslint": "9.28.0",
    "eslint-config-escapace": "5.7.1",
    "esroll": "0.4.5",
    "jsdom": "26.1.0",
    "prettier": "3.5.3",
    "prettier-config-escapace": "1.2.1",
    "syncpack": "13.0.4",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.2"
  },
  "engines": {
    "node": ">=22.15.0",
    "pnpm": ">=10.10.0"
  },
  "exports": {
    ".": {
      "node": {
        "import": {
          "types": "./lib/types/index.d.ts",
          "default": "./lib/node/index.js"
        }
      },
      "browser": {
        "import": {
          "types": "./lib/types/index.d.ts",
          "default": "./lib/browser/index.js"
        }
      },
      "default": {
        "import": {
          "types": "./lib/types/index.d.ts",
          "default": "./lib/node/index.js"
        }
      }
    }
  },
  "files": [
    "lib/browser",
    "lib/node",
    "lib/types"
  ],
  "homepage": "https://github.com/escapace/caslon/tree/trunk/packages/service-worker#readme",
  "license": "MPL-2.0",
  "peerDependencies": {
    "@vueuse/core": ">=13.3.0",
    "pinia": ">=3.0.3",
    "vue": ">=3.5.16",
    "workbox-window": ">=7.3.0"
  },
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": "escapace/caslon",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "format": "syncpack format --source package.json && eslint --no-warn-ignored --fix && prettier -uw .",
    "lint": "ls-lint --config .ls-lint.yaml && eslint",
    "ls-lint": "ls-lint --config .ls-lint.yaml",
    "test": "vitest --no-watch --coverage",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./lib/types/index.d.ts"
}
