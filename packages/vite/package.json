{
  "name": "@caslon/vite",
  "version": "0.0.0",
  "author": {
    "name": "escapace",
    "email": "opensource@escapace.com"
  },
  "bugs": "https://github.com/escapace/caslon/issues",
  "dependencies": {
    "@caslon/breeze": "workspace:*",
    "@tailwindcss/oxide": "^4.1.11",
    "magic-string": "^0.30.17"
  },
  "devDependencies": {
    "@ls-lint/ls-lint": "2.3.1",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.10.13",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.31.0",
    "eslint-config-escapace": "5.9.2",
    "esroll": "0.4.5",
    "lodash-es": "4.17.23",
    "prettier": "3.6.2",
    "prettier-config-escapace": "1.2.1",
    "syncpack": "13.0.4",
    "tsx": "4.20.3",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22.15.0",
    "pnpm": ">=10.10.0"
  },
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/node/index.js"
    }
  },
  "files": [
    "lib/node",
    "lib/types"
  ],
  "homepage": "https://github.com/escapace/caslon/tree/trunk/packages/vite#readme",
  "license": "MPL-2.0",
  "module": "./lib/node/index.js",
  "peerDependencies": {
    "@vitejs/plugin-vue": ">=6.0.0",
    "vite": ">=7.0.8",
    "vue": ">=3.5.17"
  },
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": "escapace/caslon",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "format": "syncpack format --source package.json && eslint --no-warn-ignored --fix && prettier -uw .",
    "lint": "ls-lint --config .ls-lint.yaml && eslint",
    "ls-lint": "ls-lint --config .ls-lint.yaml",
    "test": "vitest --no-watch --coverage",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./lib/types/index.d.ts"
}
