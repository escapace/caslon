{
  "name": "@caslon/cepheus",
  "version": "0.0.0",
  "author": {
    "name": "escapace",
    "email": "opensource@escapace.com"
  },
  "bugs": "https://github.com/escapace/caslon/issues",
  "devDependencies": {
    "@ls-lint/ls-lint": "2.3.1",
    "@types/node": "24.0.7",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.30.0",
    "eslint-config-escapace": "5.7.1",
    "esroll": "0.4.5",
    "jsdom": "26.1.0",
    "prettier": "3.6.2",
    "prettier-config-escapace": "1.2.1",
    "syncpack": "13.0.4",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22.15.0",
    "pnpm": ">=10.10.0"
  },
  "exports": {
    ".": {
      "node": {
        "import": {
          "types": "./lib/types/index.d.ts",
          "default": "./lib/node/index.js"
        }
      },
      "browser": {
        "import": {
          "types": "./lib/types/index.d.ts",
          "default": "./lib/browser/index.js"
        }
      },
      "default": {
        "import": {
          "types": "./lib/types/index.d.ts",
          "default": "./lib/node/index.js"
        }
      }
    },
    "./browser": {
      "import": {
        "types": "./lib/types/browser.d.ts",
        "default": "./lib/browser/browser.js"
      }
    },
    "./node": {
      "import": {
        "types": "./lib/types/node.d.ts",
        "default": "./lib/node/node.js"
      }
    }
  },
  "files": [
    "lib/browser",
    "lib/node",
    "lib/types"
  ],
  "homepage": "https://github.com/escapace/caslon/tree/trunk/packages/cepheus#readme",
  "license": "MPL-2.0",
  "peerDependencies": {
    "@caslon/utilities": "workspace:*",
    "@cassiopeia/vue": ">=7.0.3",
    "@cepheus/plugin": ">=3.0.0",
    "@cepheus/vue": ">=3.0.0",
    "@escapace/env": ">=0.1.0",
    "@pinia/colada": ">=0.17.1",
    "@unhead/vue": ">=2.0.11",
    "@vueuse/core": ">=13.4.0",
    "cassiopeia": ">=7.0.3",
    "cepheus": ">=3.0.0",
    "hono": ">=4.8.3",
    "pinia": ">=3.0.3",
    "seedpods": ">=1.2.0",
    "vue": ">=3.5.17",
    "zod": ">=3.25.67"
  },
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": "escapace/caslon",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "format": "syncpack format --source package.json && eslint --no-warn-ignored --fix && prettier -uw .",
    "lint": "ls-lint --config .ls-lint.yaml && eslint",
    "ls-lint": "ls-lint --config .ls-lint.yaml",
    "test": "vitest --no-watch --coverage",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./lib/types/index.d.ts"
}
