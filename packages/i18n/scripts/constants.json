{
  "builds": {
    "browser": {
      "define": {
        "__ENVIRONMENT__": "\"production\"",
        "__PLATFORM__": "\"browser\""
      },
      "entryPoints": ["src/browser.ts", "src/index.ts"],
      "mainFields": ["module", "browser", "main"],
      "outdir": "lib/browser",
      "platform": "browser",
      "target": ["chrome135", "firefox137", "edge135", "opera116", "safari18.4"]
    },
    "node": {
      "define": {
        "__ENVIRONMENT__": "\"production\"",
        "__PLATFORM__": "\"node\""
      },
      "entryPoints": ["src/index.ts", "src/node.ts"],
      "mainFields": ["module", "main"],
      "outdir": "lib/node",
      "platform": "node",
      "target": ["node22.15.0"]
    }
  }
}
