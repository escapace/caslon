{
  "name": "@caslon/i18n",
  "version": "0.0.0",
  "author": {
    "name": "escapace",
    "email": "opensource@escapace.com"
  },
  "bugs": "https://github.com/escapace/caslon/issues",
  "devDependencies": {
    "@ls-lint/ls-lint": "2.3.1",
    "@types/node": "24.10.13",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.31.0",
    "eslint-config-escapace": "5.9.2",
    "esroll": "0.4.5",
    "jsdom": "26.1.0",
    "prettier": "3.6.2",
    "prettier-config-escapace": "1.2.2",
    "syncpack": "13.0.4",
    "tsx": "4.20.3",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22.15.0",
    "pnpm": ">=10.10.0"
  },
  "exports": {
    ".": {
      "node": {
        "import": {
          "types": "./lib/types/index.d.ts",
          "default": "./lib/node/index.js"
        }
      },
      "browser": {
        "import": {
          "types": "./lib/types/index.d.ts",
          "default": "./lib/browser/index.js"
        }
      },
      "default": {
        "import": {
          "types": "./lib/types/index.d.ts",
          "default": "./lib/node/index.js"
        }
      }
    },
    "./node": {
      "import": {
        "types": "./lib/types/node.d.ts",
        "default": "./lib/node/node.js"
      }
    }
  },
  "files": [
    "lib/browser",
    "lib/node",
    "lib/types"
  ],
  "homepage": "https://github.com/escapace/caslon/tree/trunk/packages/i18n#readme",
  "license": "MPL-2.0",
  "peerDependencies": {
    "@caslon/utilities": "workspace:*",
    "@escapace/accept-language-parser": ">=2.1.2",
    "@escapace/canonicalize": ">=0.1.2",
    "@pangram/font-loader": ">=2.3.1",
    "@pinia/colada": ">=0.17.1",
    "@unhead/vue": ">=2.0.12",
    "fast-equals": ">=5.2.2",
    "hono": ">=4.12.14",
    "pinia": ">=3.0.3",
    "seedpods": ">=1.2.0",
    "vue": ">=3.5.17",
    "zod": ">=4.0.5"
  },
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": "escapace/caslon",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "format": "syncpack format --source package.json && eslint --no-warn-ignored --fix && prettier -uw .",
    "lint": "ls-lint --config .ls-lint.yaml && eslint",
    "ls-lint": "ls-lint --config .ls-lint.yaml",
    "test": "vitest --no-watch --coverage",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./lib/types/index.d.ts"
}
